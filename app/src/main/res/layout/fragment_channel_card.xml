<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Single-channel "card" page used by the ViewPager2 carousel.
  ~ Shows channel name, a hint that ◀/▶ (knob) cycles channels,
  ~ a member count, and the users currently in this channel.
  -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/padding_small">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/channelCardArrowLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◀"
            android:textSize="14sp"
            android:paddingEnd="@dimen/padding_small"/>

        <TextView
            android:id="@+id/channelCardName"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:ellipsize="end"
            android:maxLines="1"/>

        <TextView
            android:id="@+id/channelCardArrowRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="14sp"
            android:paddingStart="@dimen/padding_small"/>
    </LinearLayout>

    <TextView
        android:id="@+id/channelCardMembers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:gravity="center"
        android:paddingTop="2dp"
        android:paddingBottom="@dimen/padding_small"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/channelCardUserList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>
