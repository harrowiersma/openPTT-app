<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Single tile in the channel carousel — shows channel name + member
  ~ count only. The user list for the current channel lives in the
  ~ parent fragment_channel_carousel.xml so it can fill whatever
  ~ vertical space is left after the carousel strip (adaptive: on
  ~ smaller screens the users list shrinks naturally).
  -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="6dp">

    <TextView
        android:id="@+id/channelCardName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:ellipsize="end"
        android:maxLines="1"/>

    <TextView
        android:id="@+id/channelCardMembers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#BBBBBB"
        android:gravity="center"
        android:paddingTop="2dp"/>
</LinearLayout>
