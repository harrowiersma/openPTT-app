<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Full-screen "in call" view raised the moment the operator's
  ~ session enters Phone/Call-<slot>. Runs a duration timer from
  ~ Activity onCreate and finishes itself as soon as the session
  ~ leaves the Call-* sub-channel (hangup or move).
  ~
  ~ Mirrors the Hytera-native in-call screen: headline "ON CALL",
  ~ caller ID large, Call-<slot> under it, timer, and a bottom-bar
  ~ hardware-key hint telling the operator which key hangs up.
  -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#0A0A0A"
    android:padding="10dp">

    <TextView
        android:id="@+id/activeCallHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="ON CALL"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#00C853"
        android:letterSpacing="0.2"/>

    <TextView
        android:id="@+id/activeCallCallerId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:singleLine="true"
        android:ellipsize="end"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"/>

    <TextView
        android:id="@+id/activeCallChannel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#BBBBBB"
        android:paddingTop="2dp"/>

    <TextView
        android:id="@+id/activeCallDuration"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:fontFamily="monospace"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#EEEEEE"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/activeCallHangup"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginBottom="8dp"
        android:text="HANG UP\nMENU key"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="12sp"
        android:lineSpacingExtra="1dp"
        app:backgroundTint="#B71C1C"
        app:cornerRadius="10dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"/>
</LinearLayout>
