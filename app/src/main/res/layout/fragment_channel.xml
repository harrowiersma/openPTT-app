<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/channelcontainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/channel_view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <androidx.viewpager.widget.PagerTabStrip
            android:id="@+id/channel_tab_strip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"/>
    </androidx.viewpager.widget.ViewPager>

    <FrameLayout
        android:id="@+id/target_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?colorPrimaryDark">

        <TextView
            android:id="@+id/target_panel_warning"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Shouting to Channel"
            android:textSize="6pt"
            android:textColor="?android:textColorPrimaryInverse"
            android:singleLine="true"
            android:gravity="left|center_vertical"
            android:textStyle="italic"
            android:padding="8dp"/>

        <ImageView
            android:id="@+id/target_panel_cancel"
            android:layout_width="24dp"
            android:layout_height="match_parent"
            app:srcCompat="@drawable/ic_action_delete_dark"
            android:tint="?android:textColorPrimaryInverse"
            android:layout_gravity="center_vertical|end"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </FrameLayout>

    <!-- Bottom bar: Prev | PTT | Next. Prev/Next are softkey labels
         (Hytera convention) matching the D-pad LEFT/RIGHT + rotary
         knob keycodes that MumlaActivity.dispatchKeyEvent maps to
         switchChannel(). They stay put even when the PTT button is
         hidden (mute/suppressed) so the operator's navigation hint
         never disappears. -->
    <LinearLayout
        android:id="@+id/pushtotalk_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="#101010">

        <TextView
            android:id="@+id/softkeyLeft"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="◀ PREV"
            android:gravity="start|center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:textColor="#FFC107"
            android:textStyle="bold"
            android:textSize="11sp"
            android:maxLines="2"
            android:lineSpacingExtra="-2dp"/>

        <!-- Round PTT button. cornerRadius equal to half the height turns
             a square MaterialButton into a circle; we size 56x56dp with
             only the mic icon inside (no text label — a radio operator
             reads the transmit state from the color, not a word). -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/pushtotalk"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:contentDescription="@string/ptt"
            app:backgroundTint="@drawable/ptt_button_tint"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_action_microphone"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="28dp"
            app:iconTint="#FFFFFF"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp" />

        <TextView
            android:id="@+id/softkeyRight"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="NEXT ▶"
            android:gravity="end|center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:textColor="#FFC107"
            android:textStyle="bold"
            android:textSize="11sp"
            android:maxLines="2"
            android:lineSpacingExtra="-2dp"/>
    </LinearLayout>

</LinearLayout>
