<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Full-screen incoming-call overlay. Tuned for the 240x320 P50:
  ~ one big caller-id line, two chunky buttons below. Answer pipes
  ~ the user into Phone/Call-<slot>; Decline just dismisses.
  -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#0A0A0A"
    android:padding="12dp">

    <TextView
        android:id="@+id/incomingCallHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="INCOMING CALL"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#FFC107"
        android:letterSpacing="0.2"/>

    <TextView
        android:id="@+id/incomingCallCallerId"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:singleLine="true"
        android:ellipsize="end"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"/>

    <TextView
        android:id="@+id/incomingCallChannel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#BBBBBB"
        android:paddingBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/incomingCallDecline"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="DECLINE"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"
            app:backgroundTint="#B71C1C"
            app:cornerRadius="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/incomingCallAnswer"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="ANSWER"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"
            app:backgroundTint="#00C853"
            app:cornerRadius="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>
    </LinearLayout>
</LinearLayout>
