<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ User row sized for the carousel on 240x320 radio screens: taller
  ~ row + larger text + light text color that reads on dark theme.
  ~ Right-hand "status" TextView shows the operator's current state
  ~ (Online / PTT / Muted / Deafened) so a supervisor can tell at a
  ~ glance who's available without relying on the icon glyph alone.
  -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/channel_card_user_row_layout"
    android:layout_width="match_parent"
    android:layout_height="32dp"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/user_row_state"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginLeft="4dp"
        app:srcCompat="@drawable/ic_talking_off" />

    <TextView
        android:id="@+id/user_row_name"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:lines="1"
        android:paddingLeft="8dp"
        android:paddingRight="4dp"
        android:singleLine="true"
        android:textColor="?attr/callUiUserRowText"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/user_row_status"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="end|center_vertical"
        android:paddingEnd="6dp"
        android:paddingStart="4dp"
        android:textColor="#4CAF50"
        android:textSize="11sp"
        android:textStyle="bold"/>
</LinearLayout>
