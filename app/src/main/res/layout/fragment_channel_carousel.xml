<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Channel carousel host.
  ~ Layout top-down: CHANNELS header / ViewPager2 tile + floating
  ~ prev/next pills / page dots / CURRENT USERS band / user list.
  ~ Colors come from theme attrs (?attr/callUi*) so the Theme
  ~ preference (system/light/dark) actually produces a readable UI
  ~ in both modes.
  -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/callUiBg">

    <TextView
        android:id="@+id/channelCarouselHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CHANNELS"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="11sp"
        android:textColor="?attr/callUiTextMuted"
        android:letterSpacing="0.15"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/channelCarouselPager"
            android:layout_width="match_parent"
            android:layout_height="70dp"/>

        <TextView
            android:id="@+id/softkeyLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="4dp"
            android:background="@drawable/softkey_pill_bg"
            android:text="◀"
            android:textColor="?attr/callUiSoftkey"
            android:textStyle="bold"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:gravity="center"
            android:maxWidth="110dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>

        <TextView
            android:id="@+id/softkeyRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="4dp"
            android:background="@drawable/softkey_pill_bg"
            android:text="▶"
            android:textColor="?attr/callUiSoftkey"
            android:textStyle="bold"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:gravity="center"
            android:maxWidth="110dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/channelCarouselDots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="2dp"
        android:paddingBottom="4dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/callUiDivider"/>

    <TextView
        android:id="@+id/channelCurrentUsersBand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:letterSpacing="0.10"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="?attr/callUiBandBg"
        android:gravity="start|center_vertical"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/channelCurrentUsersList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>
