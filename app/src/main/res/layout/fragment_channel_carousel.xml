<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Channel carousel host.
  ~
  ~ Layout top-down:
  ~   1. "CHANNELS" header band.
  ~   2. FrameLayout that overlays the ViewPager2 (current channel
  ~      tile) with two floating pill chips anchored to either side —
  ~      the left pill shows the previous channel destination, the
  ~      right the next. Pills live here (next to the channel name)
  ~      instead of the bottom PTT row so the operator's eye doesn't
  ~      confuse them with the system-nav Back/Menu buttons.
  ~   3. Page dots.
  ~   4. "CURRENT USERS" band with online count.
  ~   5. RecyclerView user list (weight=1, absorbs remaining space).
  -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/channelCarouselHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CHANNELS"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="11sp"
        android:textColor="#9E9E9E"
        android:letterSpacing="0.15"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/channelCarouselPager"
            android:layout_width="match_parent"
            android:layout_height="70dp"/>

        <TextView
            android:id="@+id/softkeyLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="4dp"
            android:background="@drawable/softkey_pill_bg"
            android:text="◀"
            android:textColor="#FFC107"
            android:textStyle="bold"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:maxWidth="96dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>

        <TextView
            android:id="@+id/softkeyRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="4dp"
            android:background="@drawable/softkey_pill_bg"
            android:text="▶"
            android:textColor="#FFC107"
            android:textStyle="bold"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:maxWidth="96dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/channelCarouselDots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="2dp"
        android:paddingBottom="4dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"/>

    <TextView
        android:id="@+id/channelCurrentUsersBand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:letterSpacing="0.10"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#161616"
        android:gravity="start|center_vertical"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/channelCurrentUsersList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>
