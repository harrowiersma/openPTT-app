<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Pill background for the "◀ <channel>" / "<channel> ▶" chips that
  ~ flank the PTT button. The rounded container reads as an app-level
  ~ element, visually distinct from whatever system nav buttons sit
  ~ directly below it — so an operator doesn't mistake "NEXT" for the
  ~ Android Back button.
  -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
       android:shape="rectangle">
    <solid android:color="#242424"/>
    <stroke android:width="1dp" android:color="#4A4A4A"/>
    <corners android:radius="14dp"/>
</shape>
