<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Rounded pill behind the carousel status indicator. Uses theme
  ~ attrs so the fill + stroke flip correctly between the light/dark
  ~ Theme preferences — same approach as softkey_pill_bg.
  -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <corners android:radius="999dp"/>
    <solid android:color="?attr/callUiBandBg"/>
    <stroke android:width="1dp" android:color="?attr/callUiDivider"/>
</shape>
